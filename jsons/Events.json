                            "Gain a free [Mounted Archery Focus] [in capital]",
                            "Gain a free [Mercenary Camp] [in capital] <in cities without a [Mercenary Camp]>",
                            "Gain [1000] [Gold] <when below [4] [Manpower]> <when below [2] [Horses]>",
                            "Gain [2000] [Gold] <when below [8] [Manpower]> <when below [3] [Horses]>",
                            "[1] free [Mercenary Horse Archer] units appear <when above [0] [Mercenary (Eastern)]>",
                            "[1] free [Horse Archer] units appear <when above [4] [Manpower]> <when above [1] [Horses]>",
                            "[1] free [Horse Archer] units appear <when above [8] [Manpower]> <when above [3] [Horses]>",
                            "[-5 Gold] [in all cities] <for [10] turns>"
                            "[-3 Happiness] [in all cities] <in cities with a [Mercenary Camp]> <for [10] turns>"
                        ]
                    },
                    {
                        "text": "Secure the Balkan passes",
                        "uniques": [
                            "Instantly provides [1] [Thracia P] <hidden from users>",
        			"Gain a free [Heavy Infantry Focus] [in capital] <in cities without a [Heavy Infantry Focus]>",
                            	"Gain [1000] [Gold] <when below [4] [Manpower]>",
                            	"[1] free [Limitanei] units appear <when above [3] [Manpower]>",
