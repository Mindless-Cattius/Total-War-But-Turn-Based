            {
                "name": "The Loss of Macedonia",
                "text": "The Loss of Macedonia \n\n Macedonia has slipped from imperial control. Once the homeland of kings and conquerors, it now supplies rebels, usurpers, and ambitious generals. History, it seems, has a sense of humor.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Revive the Macedonian phalanx",
                        "uniques": [
                            "Instantly provides [1] [Macedonia P] <hidden from users>",
                            "Gain a free [Spear Focus] [in capital] <in cities without a [Spear Focus]>",
                            "Gain [800] [Gold] <when below [3] [Manpower]>",
                            "Gain [1600] [Gold] <when below [6] [Manpower]>",
                            "Gain [1000] [Gold]",
                            "[1] free [General] units appear <when above [1] [Nobles]>",
                            "[1] free [Pike Phalanx] units appear <when above [2] [Manpower]>",
                            "[1] free [Pike Phalanx] units appear <when above [5] [Manpower]>",
                            "[-2 Happiness, -2 Gold, -1 Production] [in all cities] <for [10] turns>"
                        ]
                    },
                    {
                        "text": "Abandon the province",
                        "uniques": [
                            "Instantly provides [1] [Macedonia P] <hidden from users>",
                            "Gain [5000]-[13000] [Gold]",
                            "[-3 Happiness, -2 Food, +1 Production] [in all cities] <for [10] turns>"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Alexander left. The problems stayed.",
                        "link": "Buildings/Macedonia"
                    }
                ]
            },
            {
