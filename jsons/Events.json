			//Roman

            {
                "name": "The Fall of Pannonia",
                "text": "The Danubian frontier has collapsed. Pannonia, once a shield against northern incursions, now lies exposed to raiders and migrating tribes. Refugees flood southward while frontier commanders demand reinforcements, warning that today's border skirmish may become tomorrow's invasion. The treasury insists everything is under control, which is usually an excellent indicator that it is not.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Raise new Danubian legions",
                        "uniques": [
                            "Instantly provides [1] [Pannonia] <hidden from users>",
                            "[-2 Gold] [in all cities] <for [15] turns>",
				"[1] free [Illyrian Legion] units appear <when above [4] [Manpower]> <when above [0] [Iron]>",
				"[2] free [Illyrian Legion] units appear <when above [9] [Manpower]> <when above [1] [Iron]>",
                            "Gain [2300] [Gold] <when below [10] [Manpower]> <when below [2] [Iron]>",
                            "Gain [1200] [Gold] <when below [5] [Manpower]> <when below [1] [Iron]>",
                        ]
                    },
                    {
                        "text": "Strengthen the cavalry",
                        "uniques": [
                            "Instantly provides [1] [Pannonia] <hidden from users>",
			"Only available <if [Mounted Focus] is not constructed>",
        		"Gain a free [Mounted Focus] [in capital]",
                            "[-2 Gold] [in all cities] <for [15] turns>"
                        ]
                    },
                    {
                        "text": "Abandon the frontier settlements",
                        "uniques": [
                            "Instantly provides [1] [Pannonia] <hidden from users>",
                            "Gain [6000] [Gold]",
                            "[-1 Happiness, -1 Food] [in all cities] <for [10] turns>"
                        ]
                    }
                ],

},
{
		"name": "The Loss of Dalmatia",
		"text": "Dalmatia is lost. The Adriatic coast now belongs to ambitious warlords, opportunistic pirates, and former taxpayers. Historians call this a crisis. Tax collectors call it a disaster.",
		"presentation":"Alert",
		"choices": [
			{
			"text": "Mobilize the provincial elite",
			"uniques": [
				"Instantly provides [1] [Dalmatia] <hidden from users>",
				"Only available <if [Mounted Focus] is not constructed>",
				"Gain a free [Mounted Focus] [in capital]",
				"Gain [1000] [Gold] <when below [4] [Manpower]> <when below [2] [Horses]>",
				"Gain [2000] [Gold] <when below [8] [Manpower]> <when below [3] [Horses]>",
				"Gain [1000] [Gold]",
				"[1] free [General] units appear <when above [1] [Nobles]>",
				"[1] free [Cavalry] units appear <when above [4] [Manpower]> <when above [1] [Horses]>",
				"[2] free [Cavalry] units appear <when above [8] [Manpower]> <when above [3] [Horses]>",
				"[-2 Happiness, -2 Gold, -1 Production] [in all cities] <for [10] turns>"
				]
		},
		{
			"text": "Fortify the Adriatic coast",
			"uniques": [
				"Instantly provides [1] [Dalmatia] <hidden from users>", 
				"Gain a free [Walls] [in all cities] <in cities without a [Walls]> <in cities with at least [15] [Population]>", 
				"Gain a free [Wall Towers] [in all cities] <in cities without a [Wall Towers]> <in cities with at least [17] [Population]>",
				"[-3 Gold] [in all cities] <for [10] turns>"
]
		},
		{
			"text": "Withdraw the remaining garrisons",
			"uniques": [
				"Instantly provides [1] [Dalmatia] <hidden from users>",
				"Gain [8000] [Gold]",
				"[-1 Happiness, -1 Food, +1 Production] [in all cities] <for [10] turns>"
				]
		}
	],
			"civilopediaText": [
		{
			"text": "The Illyrians are back, and they remembered where Rome keeps its money.",
			"link": "Buildings/Dalmatia"
		}
	]
},
            {
                "name": "The Loss of Thracia",
                "text": "Thracia has fallen beyond imperial control. The roads to Constantinople grow less secure, while ambitious warlords and restless tribes compete to inherit Rome's former authority. As usual, everyone claims they are merely restoring order.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Recruit Frontier Horsemen",
                        "uniques": [
                            "Instantly provides [1] [Thracia] <hidden from users>",
                            "Only available <if [Mounted Archery Focus] is not constructed>",
                            "Gain a free [Mounted Archery Focus] [in capital]",
                            "Gain a free [Mercenary Camp] [in capital] <in cities without a [Mercenary Camp]>",
                            "Gain [1000] [Gold] <when below [4] [Manpower]> <when below [2] [Horses]>",
                            "Gain [2000] [Gold] <when below [8] [Manpower]> <when below [3] [Horses]>",
                            "[1] free [Mercenary Horse Archer] units appear <when above [0] [Mercenary (Eastern)]>",
                            "[1] free [Horse Archer] units appear <when above [4] [Manpower]> <when above [1] [Horses]>",
                            "[2] free [Horse Archer] units appear <when above [8] [Manpower]> <when above [3] [Horses]>",
                            "[-5 Gold] [in all cities] <for [10] turns>"
                            "[-3 Happiness] [in all cities] <in cities with a [Mercenary Camp]> <for [10] turns>"
                        ]
                    },
                    {
                        "text": "Secure the Balkan passes",
                        "uniques": [
                            "Instantly provides [1] [Thracia] <hidden from users>",
        			"Gain a free [Heavy Infantry Focus] [in capital] <in cities without a [Heavy Infantry Focus]>",
                            	"Gain [1000] [Gold] <when below [4] [Manpower]>",
                            	"[1] free [Limitanei] units appear <when above [3] [Manpower]>",
                            	"[-2 Gold, +1 Happiness] [in all cities] <for [10] turns>"
