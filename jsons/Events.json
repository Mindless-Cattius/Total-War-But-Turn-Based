[
    /////RULE
{
    "name": "A Matter of Administration",
    "text": "Many of the systems governing your civilization are explained within the Civilopedia. If you are uncertain how a mechanic works, consult Civilopedia -> Resources -> Rule. There you can find detailed explanations for systems such as Sanitation and Plague, Rebel Risk and Rebellions, and many others.",
    "presentation": "Alert",
    "choices": [
        {
            "text": "THE REBEL ?!",
            "uniques": [
                "Comment [Mechanic explanations can be found in Civilopedia -> Resources -> Rebel Risk.]",
                "Triggers a [Rebel Risk?] event <hidden from users>",
                "Only available <when below [1] [Administrative Briefing]> <hidden from users>"
            ]
        },
        {
            "text": "THE PLAGUE ?!",
            "uniques": [
                "Comment [Mechanic explanations can be found in Civilopedia -> Resources -> Sanitation.]",
                "Triggers a [The Plague?] event <hidden from users>",
                "Only available <when below [1] [Administrative Briefing]> <hidden from users>"
            ]
        },
        {
            "text": "START THE GAME!!!",
            "uniques": [
                "Comment [Mechanic explanations can be found in Civilopedia -> Resources -> Rule.]",
                "Instantly provides [1] [Administrative Briefing] <hidden from users>",
                "Only available <when below [1] [Administrative Briefing]> <hidden from users>",
            ]
        }
    ],
    "civilopediaText": [
  {
        "text": "Review the Civilopedia -> Resources -> Rule for an overview of the mod's core mechanics.",
        "link": "Resources/Rule"
    },
    {
        "text": "Review the Civilopedia -> Resources -> Sanitation to learn about disease outbreaks, plague spread, and public health.",
        "link": "Resources/Sanitation"
    },
    {
        "text": "Review the Civilopedia -> Resources -> Rebel Risk to learn about unrest, rebellions, and provincial stability.",
        "link": "Resources/Rebel Risk"
    }
    ]
},
{
    "name": "Rebel Risk?",
    "text": "Throughout history, rulers have repeatedly discovered that starving, overtaxed, oppressed, or neglected subjects occasionally object to their circumstances. This objection is typically expressed through riots, revolts, and the sudden appearance of armed peasants outside the city walls.\n\nThe higher your [Rebel Risk], the greater the chance rebel armies will emerge. Watch for the [REBEL IMMINENT] warning in your turn notifications. Contrary to popular belief, rebels rarely spawn because they enjoy exercise.",
    "presentation": "Alert",
    "choices": [
        {
            "text": "I SHALL MAINTAIN ORDER!",
            "uniques": [
                "Comment [Mechanic explanations can be found in Civilopedia -> Resources -> Rebel Risk.]",
                "Triggers a [A Matter of Administration] event <hidden from users> <for [Human player] Civilizations>",
                "Only available <when below [1] [Administrative Briefing]> <hidden from users>"
            ]
        }
    ],
    "civilopediaText": [
        {
            "text": "Review the Civilopedia -> Resources -> Rebel Risk",
            "link": "Resources/Rebel Risk"
        }
    ]
},
{
    "name": "The Plague?",
    "text": "For most of human history, disease has killed more people than wars, famines, and ambitious politicians combined. Cities with poor sanitation become breeding grounds for outbreaks, and once a plague begins spreading, it tends to ignore borders, social class, and optimistic government reports.\n\nMaintain high [Sanitation] to reduce the risk of outbreaks. Watch for plague warnings in your notifications. Remember: washing your hands is considerably cheaper than burying half the empire.",
    "presentation": "Alert",
    "choices": [
        {
            "text": "BUILD MORE BATHS!",
            "uniques": [
                "Comment [Mechanic explanations can be found in Civilopedia -> Resources -> Sanitation.]",
                "Triggers a [A Matter of Administration] event <hidden from users> <for [Human player] Civilizations>",
                "Only available <when below [1] [Administrative Briefing]> <hidden from users>"
            ]
        }
    ],
    "civilopediaText": [
        {
            "text": "Review the Civilopedia -> Resources -> Sanitation",
            "link": "Resources/Sanitation"
        }
    ]
},


		////BUFF UPKEEP

            {
                "name": "Heavy Infantry Funding Review",
                "text": "The military accountants report that maintaining elite infantry formations remains expensive. Veteran officers require salaries, armor requires maintenance, and soldiers continue the radical practice of expecting food. The treasury recommends cuts. The generals recommend finding a different treasury.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Continue funding the veterans",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "The budget must survive",
                        "uniques": [
                            "Remove [Heavy Infantry Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Elite soldiers. Elite expenses.",
                        "link": "Buildings/Heavy Infantry Focus"
                    }
                ]
            },
            {
                "name": "Shield Infantry Funding Review",
                "text": "The treasury reports that maintaining heavily armed shield infantry remains expensive. Shields must be replaced, armor repaired, and veteran instructors paid. The generals argue these soldiers form the backbone of the army. The treasury argues that backbones are surprisingly expensive.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Continue funding the shield infantry",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "Suspend the reform program",
                        "uniques": [
                            "Remove [Shield Infantry Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Discipline is expensive. Defeat costs more.",
                        "link": "Buildings/Shield Infantry Focus"
                    }
                ]
            },
            {
                "name": "Sword Training Review",
                "text": "The army requests additional funding for close-combat training. Veteran officers insist that superior swordsmanship wins battles. Accountants note that dead soldiers rarely complain about insufficient training.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Continue funding the swordsmen",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "Reduce training expenditures",
                        "uniques": [
                            "Remove [Sword Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Sharp swords require sharp budgets.",
                        "link": "Buildings/Sword Focus"
                    }
                ]
            },
            {
                "name": "Horse Archer Procurement Report",
                "text": "The horse archers require replacement bows, fresh mounts, and continued training. The officers claim this investment guarantees battlefield superiority. The treasury has noticed that battlefield superiority appears to require funding every year.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Maintain the horse archers",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "End the training initiative",
                        "uniques": [
                            "Remove [Mounted Archery Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Fair fights are optional.",
                        "link": "Buildings/Mounted Archery Focus"
                    }
                ]
            },
            {
                "name": "Quality Sticks Maintenance Report",
                "text": "The spear formations continue to demand equipment, drills, and competent officers. Historians note that disciplined spearmen have defeated cavalry for centuries. Cavalry commanders have submitted a formal complaint regarding this observation.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Maintain the phalanx",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "Discontinue formation drills",
                        "uniques": [
                            "Remove [Spear Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Long spears, longer invoices.",
                        "link": "Buildings/Spear Focus"
                    }
                ]
            },
            {
                "name": "Cavalry Budget Crisis",
                "text": "The cavalry commanders have submitted another funding request. The report discusses mobility, reconnaissance, and frontier defense. Most of the expenses appear to involve feeding horses. An alarming number of horses.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Fund the cavalry",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "Scale back cavalry operations",
                        "uniques": [
                            "Remove [Mounted Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Elite horsemen. Elite horse bills.",
                        "link": "Buildings/Mounted Focus"
                    }
                ]
            },
            {
                "name": "Arrow Procurement Debate",
                "text": "Military officials insist that archers require a steady supply of arrows. Treasury officials suggest recovering arrows already fired. The military politely requests that the treasury demonstrate this strategy personally.",
                "presentation":"Alert",
                "choices": [
                    {
                        "text": "Purchase more arrows",
                        "uniques": [
                            "Only available <when above [500] [Gold]>",
                            "Gain [-300]-[-700] [Gold]"
                        ]
                    },
                    {
                        "text": "Reduce arrow allocations",
                        "uniques": [
                            "Remove [Archery Focus] [in all cities]"
                        ]
                    }
                ],
                "civilopediaText": [
                    {
                        "text": "Arrows are cheaper than funerals.",
                        "link": "Buildings/Archery Focus"
                    }
                ]
            },


